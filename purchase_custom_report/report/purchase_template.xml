<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="template_purchase_order_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <t t-set="company" t-value="doc.company_id"/>

                <t t-call="base_custom_report.custom_external_layout">

                    <style type="text/css">
                        .po-content-table { width:100%; border-collapse:collapse; margin-top:10px; }
                        .po-content-table th { padding:5px; border:1px solid #000; text-align:left; background-color:#f0f0f0; }
                        .po-content-table td { padding:5px; border:1px solid #000; }
                        .text-right { text-align:right; }
                        .text-center { text-align:center; }

                        /* --- TRIK CSS UNICODE BYPASS UNTUK MATA UANG --- */
                        .cur-EUR::before { content: "\20AC"; }
                        .cur-GBP::before { content: "\00A3"; }
                        .cur-JPY::before { content: "\00A5"; }
                        .cur-CNY::before { content: "\00A5"; }
                    </style>

                    <div class="row" style="margin-bottom: 20px; align-items: center;">
                        <div class="col-6" style="font-size:28px !important; font-weight:700; color: #102e5f;">
                            PURCHASE ORDER
                        </div>
                        <div class="col-6" style="text-align: right;">
                            <div style="display: inline-block; text-align: right; width: 250px;">
                                <span t-field="doc.name" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 100, 'img_style': 'width:100%; height:40px;'}"/>
                                <div style="font-size: 12px; letter-spacing: 2px; font-family: monospace; font-weight: bold; margin-top: 4px;">
                                    *PO-<span t-esc="doc.name"/>*
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row" style="margin-bottom: 20px; font-size: 13px;">
                        <div class="col-6" style="padding-right: 15px;">
                            <div style="font-weight:700; margin-bottom:4px; color:#555555;">Shipping Address:</div>
                            <t t-set="ship_partner" t-value="doc.picking_type_id.warehouse_id.partner_id or doc.company_id.partner_id"/>
                            <div style="font-weight:700;"><span t-esc="(ship_partner.name or '').upper()"/></div>
                            <div><span t-esc="ship_partner.street"/></div>
                            <div><span t-esc="ship_partner.city"/> <t t-if="ship_partner.zip">(<span t-esc="ship_partner.zip"/>)</t></div>
                            <div t-if="ship_partner.country_id"><span t-esc="ship_partner.country_id.name"/></div>
                            <div style="margin-top: 4px;"><strong>Telp:</strong> <span t-esc="ship_partner.phone or ship_partner.mobile or '-'"/></div>
                            <div><strong>Email:</strong> <span t-esc="ship_partner.email or '-'"/></div>
                        </div>

                        <div class="col-6">
                            <div style="font-weight:700; margin-bottom:4px; color:#555555;">Vendor:</div>
                            <div style="font-weight:700;"><span t-esc="(doc.partner_id.name or '').upper()"/></div>
                            <div><span t-esc="doc.partner_id.street"/></div>
                            <div><span t-esc="doc.partner_id.city"/> <t t-if="doc.partner_id.zip">(<span t-esc="doc.partner_id.zip"/>)</t></div>

                            <table style="width: 100%; margin-top: 6px;">
                                <tr>
                                    <td style="width: 40%; padding: 1px 0;"><strong>PIC Vendor:</strong></td>
                                    <td><span t-esc="doc.partner_id.pic or '-'"/></td>
                                </tr>
                                <tr t-if="doc.partner_id.vat">
                                    <td style="padding: 1px 0;"><strong>NPWP:</strong></td>
                                    <td><span t-esc="doc.partner_id.vat"/></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1px 0;"><strong>Order Date:</strong></td>
                                    <td><span t-field="doc.date_order" t-options='{"widget":"date","format":"dd/MM/yyyy"}'/></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1px 0;"><strong>Est. Date:</strong></td>
                                    <td><span t-field="doc.date_planned" t-options='{"widget":"date","format":"dd/MM/yyyy"}'/></td>
                                </tr>
                                <tr>
                                    <td style="padding: 1px 0;"><strong>Payment Term:</strong></td>
                                    <td><span t-field="doc.payment_term_id"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <table class="po-content-table">
                        <thead>
                            <tr>
                                <th style="width:5%; text-align:center;">No</th>
                                <th style="width:15%;">Kode</th>
                                <th>Description</th>
                                <th style="width:10%;" class="text-right">Qty</th>
                                <th style="width:10%;">UoM</th>
                                <th style="width:15%;" class="text-right">Unit Price</th>
                                <th style="width:15%;" class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_no" t-value="0"/>
                            <t t-foreach="doc.order_line.filtered(lambda l: not l.display_type)" t-as="line">
                                <t t-set="line_no" t-value="line_no + 1"/>
                                <tr>
                                    <td class="text-center"><span t-esc="line_no"/></td>
                                    <td><span t-field="line.product_id.default_code"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-right"><span t-field="line.product_qty"/></td>
                                    <td><span t-field="line.product_uom.name"/></td>

                                    <td class="text-right">
                                        <t t-if="doc.currency_id.name in ['EUR', 'GBP', 'JPY', 'CNY']">
                                            <span t-attf-class="cur-{{ doc.currency_id.name }}" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="doc.currency_id.symbol" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <span t-field="line.price_unit" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>

                                    <td class="text-right">
                                        <t t-if="doc.currency_id.name in ['EUR', 'GBP', 'JPY', 'CNY']">
                                            <span t-attf-class="cur-{{ doc.currency_id.name }}" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="doc.currency_id.symbol" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="row" style="margin-top: 15px; page-break-inside: avoid;">
                        <div class="col-7">
                            <t t-if="doc.notes">
                                <div style="font-size: 11px; color: #333333; padding-right: 20px; text-align: justify;">
                                    <strong style="font-size: 12px; color: #102e5f;">Terms and Conditions / Notes:</strong><br/>
                                    <span t-field="doc.notes"/>
                                </div>
                            </t>
                        </div>

                        <div class="col-5">
                            <table style="width:100%; border-collapse:collapse; border:1px solid #000;">
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-bottom:1px solid #000; border-right:none;">Subtotal</td>
                                    <td class="text-right" style="border-bottom:1px solid #000; border-left:none;">
                                        <t t-if="doc.currency_id.name in ['EUR', 'GBP', 'JPY', 'CNY']">
                                            <span t-attf-class="cur-{{ doc.currency_id.name }}" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="doc.currency_id.symbol" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <span t-field="doc.amount_untaxed" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-bottom:1px solid #000; border-right:none;">Taxes</td>
                                    <td class="text-right" style="border-bottom:1px solid #000; border-left:none;">
                                        <t t-if="doc.currency_id.name in ['EUR', 'GBP', 'JPY', 'CNY']">
                                            <span t-attf-class="cur-{{ doc.currency_id.name }}" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="doc.currency_id.symbol" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <span t-field="doc.amount_tax" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-right:none; background-color: #f0f0f0;">Total</td>
                                    <td class="text-right" style="font-weight:bold; border-left:none; background-color: #f0f0f0;">
                                        <t t-if="doc.currency_id.name in ['EUR', 'GBP', 'JPY', 'CNY']">
                                            <span t-attf-class="cur-{{ doc.currency_id.name }}" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="doc.currency_id.symbol" style="font-weight:bold; margin-right:4px;"/>
                                        </t>
                                        <span t-field="doc.amount_total" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div style="clear: both; padding-top: 40px; page-break-inside: avoid;">

                        <t t-set="signature_data" t-value="doc.get_tier_signature_data()"/>
                        <t t-call="base_custom_report_tier_validation.dynamic_signature_block"/>

                    </div>

                </t>
            </t>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="template_sale_order_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <t t-set="company" t-value="doc.company_id"/>

                <t t-call="base_custom_report.custom_external_layout">

                    <style type="text/css">
                        .content-table { width:100%; border-collapse:collapse; margin-top:10px; }
                        .content-table th { padding:5px; border:1px solid #000; text-align:left; background-color:#f0f0f0; }
                        .content-table td { padding:5px; border:1px solid #000; }
                        .text-right { text-align:right; }
                        .text-center { text-align:center; }
                    </style>

                    <div class="row" style="margin-bottom: 20px; align-items: center;">
                        <div class="col-6" style="font-size:28px !important; font-weight:700;">
                            <span t-if="doc.state in ['draft','sent']">QUOTATION</span>
                            <span t-if="doc.state not in ['draft','sent']">SALES ORDER</span>
                        </div>
                        <div class="col-6" style="text-align: right;">
                            <div style="display: inline-block; text-align: right; width: 250px;">
                                <span t-field="doc.name" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 100, 'img_style': 'width:100%; height:40px;'}"/>
                                <div style="font-size: 12px; letter-spacing: 2px; font-family: monospace; font-weight: bold; margin-top: 4px;">
                                    *SO-<span t-esc="doc.name"/>*
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row" style="margin-bottom: 20px;">
                        <div class="col-6">
                            <div style="font-weight:700; margin-bottom:4px;">Customer / Invoicing Address:</div>
                            <div><strong t-esc="(doc.partner_invoice_id.name or '').upper()"/></div>
                            <div><span t-esc="doc.partner_invoice_id.street"/></div>
                            <div><span t-esc="doc.partner_invoice_id.city"/> <t t-if="doc.partner_invoice_id.zip">(<span t-esc="doc.partner_invoice_id.zip"/>)</t></div>
                        </div>
                        <div class="col-6">
                            <div style="font-weight:700; margin-bottom:4px;">Shipping Address:</div>
                            <div><strong t-esc="(doc.partner_shipping_id.name or '').upper()"/></div>
                            <div><span t-esc="doc.partner_shipping_id.street"/></div>
                            <div><span t-esc="doc.partner_shipping_id.city"/> <t t-if="doc.partner_shipping_id.zip">(<span t-esc="doc.partner_shipping_id.zip"/>)</t></div>
                            <div style="margin-top:4px;"><strong>Order Date:</strong> <span t-field="doc.date_order" t-options='{"widget":"date","format":"dd/MM/yyyy"}'/></div>
                            <div><strong>Payment Term:</strong> <span t-field="doc.payment_term_id"/></div>
                        </div>
                    </div>

                    <table class="content-table">
                        <thead>
                            <tr>
                                <th style="width:5%; text-align:center;">No</th>
                                <th>Description</th>
                                <th style="width:10%;" class="text-right">Qty</th>
                                <th style="width:15%;" class="text-right">Unit Price</th>
                                <th style="width:15%;" class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_no" t-value="0"/>
                            <t t-foreach="doc.order_line.filtered(lambda l: not l.display_type)" t-as="line">
                                <t t-set="line_no" t-value="line_no + 1"/>
                                <tr>
                                    <td class="text-center"><span t-esc="line_no"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-right"><span t-field="line.product_uom_qty"/> <span t-field="line.product_uom"/></td>
                                    <td class="text-right">
                                        <span t-esc="doc.currency_id.symbol" style="margin-right:4px;"/>
                                        <span t-field="line.price_unit" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="doc.currency_id.symbol" style="margin-right:4px;"/>
                                        <span t-field="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="row" style="margin-top: 15px; page-break-inside: avoid;">
                        <div class="col-7">
                            <t t-if="doc.note">
                                <div style="font-size: 11px; color: #333333; padding-right: 20px; text-align: justify;">
                                    <strong style="font-size: 12px; color: #102e5f;">Terms and Conditions:</strong><br/>
                                    <span t-field="doc.note"/>
                                </div>
                            </t>
                        </div>
                        <div class="col-5">
                            <table style="width:100%; border-collapse:collapse; border:1px solid #000;">
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-bottom:1px solid #000; border-right:none;">Subtotal</td>
                                    <td class="text-right" style="border-bottom:1px solid #000; border-left:none;"><span t-field="doc.amount_untaxed"/></td>
                                </tr>
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-bottom:1px solid #000; border-right:none;">Taxes</td>
                                    <td class="text-right" style="border-bottom:1px solid #000; border-left:none;"><span t-field="doc.amount_tax"/></td>
                                </tr>
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-right:none; background-color: #f0f0f0;">Total</td>
                                    <td class="text-right" style="font-weight:bold; border-left:none; background-color: #f0f0f0;"><span t-field="doc.amount_total"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div style="clear: both; padding-top: 40px; page-break-inside: avoid;">
                        <t t-set="signature_data" t-value="doc.get_tier_signature_data()"/>
                        <t t-call="base_custom_report_tier_validation.dynamic_signature_block"/>
                    </div>

                </t>
            </t>
        </t>
    </template>
</odoo>

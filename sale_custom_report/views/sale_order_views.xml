<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_preview" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.preview</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_preview_report" string="Preview SO" type="object" class="oe_highlight" icon="fa-print"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="template_bill_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="doc.company_id"/>
                <t t-call="base_custom_report.custom_external_layout">

                    <style type="text/css">
                        .content-table { width:100%; border-collapse:collapse; margin-top:10px; }
                        .content-table th { padding:5px; border:1px solid #000; text-align:left; background-color:#f0f0f0; }
                        .content-table td { padding:5px; border:1px solid #000; }
                        .text-right { text-align:right; }
                        .text-center { text-align:center; }
                    </style>

                    <table style="width:100%; margin-bottom:20px; border-collapse:collapse;">
                        <tr style="vertical-align:middle;">
                            <td style="width:70%; vertical-align:middle;">
                                <div style="font-size:29px; font-weight:700; line-height:40px; color:#102e5f; margin:0; padding:0;">
                                    <span t-if="doc.move_type == 'out_invoice' and doc.state == 'posted'">
                                        CUSTOMER INVOICE
                                    </span>
                    
                                    <span t-if="doc.move_type == 'out_invoice' and doc.state == 'draft'">
                                        DRAFT INVOICE
                                    </span>
                    
                                    <span t-if="doc.move_type == 'in_invoice'">
                                        VENDOR BILL
                                    </span>
                    
                                    <span t-if="doc.move_type == 'out_refund'">
                                        CREDIT NOTE
                                    </span>
                                </div>
                            </td>
                            <td style="width:30%; text-align:right; vertical-align:middle; font-size:20px; font-weight:bold;">
                                <span t-field="doc.name"/>
                            </td>
                        </tr>
                    </table>

                    <table style="width:100%; margin-bottom:18px; border-collapse:collapse; font-size:16px; line-height:25px;">
                        <tr style="vertical-align:top;">
                    
                            <!-- Partner -->
                            <td style="width:50%;">
                    
                                <div style="font-weight:bold; margin-bottom:4px;">
                                    Partner:
                                </div>
                    
                                <div style="font-weight:bold;">
                                    <span t-field="doc.partner_id.name"/>
                                </div>
                    
                                <div>
                                    <span t-field="doc.partner_id.street"/>
                                </div>

                                <div t-if="doc.partner_id.vat">
                                    NPWP: 
                                    <span t-field="doc.partner_id.vat"/>
                                </div>
                    
                            </td>
                    
                            <!-- Invoice Information -->
                            <td style="width:50%; text-align:left;">
                    
                                <div>
                                    <strong>Invoice Date:</strong>
                                    <span t-field="doc.invoice_date"
                                          t-options='{"widget":"date","format":"dd/MM/yyyy"}'/>
                                </div>
                    
                                <div>
                                    <strong>Due Date:</strong>
                                    <span t-field="doc.invoice_date_due"
                                          t-options='{"widget":"date","format":"dd/MM/yyyy"}'/>
                                </div>
                    
                                <div>
                                    <strong>Source (PO/SO):</strong>
                                    <span t-esc="doc.invoice_origin or '-'"/>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <table class="content-table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th style="width:10%; text-align:center;">Qty</th>
                                <th style="width:15%; text-align:right;">Unit Price</th>
                                <th style="width:15%; text-align:right;">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="doc.invoice_line_ids.filtered(lambda l: l.display_type == 'product')" t-as="line">
                                <td><span t-field="line.name"/></td>
                                <td class="text-center"><span t-field="line.quantity"/></td>
                                <td class="text-right"><span t-field="line.price_unit"/></td>
                                <td class="text-right"><span t-field="line.price_subtotal"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <div style="width:100%; margin-top:15px;">

                        <!-- Notes -->
                        <div style="width:58%; float:left;">
                            <t t-if="doc.narration">
                                <div style="border-top:1px padding-top:10px; font-size:11px; color:#444; line-height:10px;">
                                    <div style="color:#102e5f; font-weight:bold; margin-bottom:4px;">
                                        Notes / Terms:
                                    </div>
                                    <span t-field="doc.narration"/>
                                </div>
                            </t>
                        </div>
                    
                        <!-- Total -->
                        <div style="width:38%; float:right;">
                            <table style="width:100%; border-collapse:collapse; border:1px solid #000;">
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-bottom:1px solid #000; border-right:none;">Subtotal</td>
                                    <td class="text-right" style="border-bottom:1px solid #000; border-left:none;"><span t-field="doc.amount_untaxed"/></td>
                                </tr>
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-bottom:1px solid #000; border-right:none;">Taxes</td>
                                    <td class="text-right" style="border-bottom:1px solid #000; border-left:none;"><span t-field="doc.amount_tax"/></td>
                                </tr>
                                <tr>
                                    <td style="padding:4px; font-weight:bold; border-right:none; background-color: #f0f0f0;">Total</td>
                                    <td class="text-right" style="font-weight:bold; border-left:none; background-color: #f0f0f0;"><span t-field="doc.amount_total"/></td>
                                </tr>
                            </table>
                        </div>
                    
                        <div style="clear:both;"></div>
                    
                    </div>

                    <div style="width:100%; margin-top:70px; page-break-inside:avoid; font-size:14px;">

                        <div style="width:50%; float:left; text-align:center;">
                    
                            <div style="margin-bottom:70px;">
                                Dibuat Oleh,
                            </div>
                    
                            <div style="width:60%; margin:0 auto; border-top:1px solid #000;"></div>
                    
                            <div style="margin-top:5px;">
                                (Finance)
                            </div>
                    
                        </div>
                    
                        <div style="width:50%; float:right; text-align:center;">
                    
                            <div style="margin-bottom:70px;">
                                Diketahui Oleh,
                            </div>
                    
                            <div style="width:60%; margin:0 auto; border-top:1px solid #000;"></div>
                    
                            <div style="margin-top:5px;">
                                (Finance Manager)
                            </div>
                    
                        </div>
                    
                        <div style="clear:both;"></div>
                    
                    </div>

                </t>
            </t>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_preview" model="ir.ui.view">
        <field name="name">account.move.form.inherit.preview</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_preview_report"
                        string="Preview Document"
                        type="object"
                        class="oe_highlight"
                        icon="fa-print"
                        attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'in_invoice', 'out_refund', 'in_refund'))]}"/>
            </xpath>
        </field>
    </record>
</odoo>

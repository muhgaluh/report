<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="template_delivery_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <t t-set="company" t-value="doc.company_id"/>

                <t t-call="base_custom_report.custom_external_layout">

                    <style type="text/css">
                        .do-content-table { width:100%; border-collapse:collapse; margin-top:10px; margin-bottom:15px; page-break-inside: avoid; }
                        .do-content-table th { padding:6px; border:1px solid #000; text-align:center; background-color:#f0f0f0; }
                        .do-content-table td { padding:6px; border:1px solid #000; vertical-align: middle; }
                        .text-center { text-align:center; }
                        .text-left { text-align:left; }
                        .text-right { text-align:right; }

                        .fake-checkbox {
                            display: inline-block;
                            width: 13px;
                            height: 13px;
                            border: 1px solid #000;
                            margin-right: 6px;
                            vertical-align: middle;
                        }
                        .keperluan-table { width:100%; border-collapse:collapse; }
                        .keperluan-table td { border:none !important; padding:2px 0; }
                    </style>

                    <table style="width:100%; margin-bottom:15px; border-collapse:collapse;">
                        <tr style="vertical-align:middle;">
                    
                            <!-- Judul -->
                            <td style="width:70%; vertical-align:middle;">
                                <div style="font-size:29px; font-weight:700; color:#102e5f; line-height:40px; letter-spacing:-0.5px;">
                                    DELIVERY ORDER
                                </div>
                            </td>
                    
                            <!-- Barcode -->
                            <td style="width:30%; text-align:right; vertical-align:middle;">
                    
                                <div style="display:inline-block; width:260px;">
                    
                                    <span t-field="doc.name"
                                        t-options="{
                                            'widget':'barcode',
                                            'symbology':'Code128',
                                            'width':600,
                                            'height':100,
                                            'img_style':'width:100%; height:40px;'
                                        }"/>
                    
                                    <div style="margin-top:4px; text-align:center; font-size:12px; font-family:monospace; font-weight:bold; letter-spacing:2px;">
                                        *<span t-esc="doc.name"/>*
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <table style="width:100%; margin-bottom:15px; border-collapse:collapse; font-size:13px;">
                        <tr style="vertical-align:top;">
                    
                            <!-- ===================== -->
                            <!-- Kepada Yth -->
                            <!-- ===================== -->
                            <td style="width:50%; padding-right:25px; vertical-align:top;">
                    
                                <div style="font-weight:700; color:#555555; margin-bottom:5px;">
                                    Kepada Yth:
                                </div>
                    
                                <div style="font-size:15px; font-weight:bold; margin-bottom:3px;">
                                    <span t-esc="(doc.partner_id.name or '').upper()"/>
                                </div>
                    
                                <div style="margin-bottom:2px;">
                                    <span t-field="doc.partner_id.street"/>
                                </div>
                    
                                <div t-if="doc.partner_id.street2" style="margin-bottom:2px;">
                                    <span t-field="doc.partner_id.street2"/>
                                </div>
                    
                                <div style="margin-bottom:2px;">
                                    <span t-field="doc.partner_id.city"/>
                                    <t t-if="doc.partner_id.zip">
                                        (<span t-field="doc.partner_id.zip"/>)
                                    </t>
                                </div>
                    
                                <div t-if="doc.partner_id.phone" style="margin-top:4px;">
                                    Telp:
                                    <span t-field="doc.partner_id.phone"/>
                                </div>
                    
                                <div t-if="doc.partner_id.vat"
                                     style="margin-top:4px;font-size:11px;">
                                    <strong>NPWP:</strong>
                                    <span t-field="doc.partner_id.vat"/>
                                </div>
                    
                            </td>
                    
                            <!-- ===================== -->
                            <!-- Garis Tengah -->
                            <!-- ===================== -->
                            <td style="width:1%; border-left:1px dashed #cfcfcf;"></td>
                    
                            <!-- ===================== -->
                            <!-- Untuk Keperluan -->
                            <!-- ===================== -->
                            <td style="width:49%; padding-left:25px; vertical-align:top;">
                    
                                <div style="font-weight:700; color:#555555; margin-bottom:6px;">
                                    Untuk Keperluan:
                                </div>
                    
                                <table style="width:100%; border-collapse:collapse;">
                    
                                    <tr>
                                        <td style="width:50%; border:1px solid #555; padding:4px;">
                                            &#9744; Service
                                        </td>
                    
                                        <td style="border:1px solid #555; padding:4px;">
                                            &#9744; Dipinjamkan
                                        </td>
                                    </tr>
                    
                                    <tr>
                                        <td style="border:1px solid #555; padding:4px;">
                                            &#9744; Subkont
                                        </td>
                    
                                        <td style="border:1px solid #555; padding:4px;">
                                            &#9744; Dijual
                                        </td>
                                    </tr>
                    
                                    <tr>
                                        <td style="border:1px solid #555; padding:4px;">
                                            &#9744; Return
                                        </td>
                    
                                        <td style="border:1px solid #555; padding:4px;">
                                            &#9744; ____________
                                        </td>
                                    </tr>
                    
                                </table>
                    
                            </td>
                    
                        </tr>
                    </table>

                    <table style="width:100%; border:1px solid #000; border-collapse:collapse; margin-bottom:15px; font-size:13px;">
                        <tr>
                            <td style="width:50%; padding:7px; border-right:1px solid #000;">
                                <strong>Delivery Order Number:</strong>
                                <span style="margin-left:8px; font-weight:bold;" t-field="doc.name"/>
                            </td>
                            <td style="width:50%; padding:7px;">
                                <strong>Delivery Date:</strong>
                                <span style="margin-left:8px;" t-if="doc.date_done" t-field="doc.date_done" t-options='{"widget":"datetime","format":"dd/MM/yyyy HH:mm:ss"}'/>
                                <span style="margin-left:8px;" t-if="not doc.date_done" t-field="doc.scheduled_date" t-options='{"widget":"datetime","format":"dd/MM/yyyy"}'/>
                            </td>
                        </tr>
                    </table>

                    <table class="do-content-table">
                        <thead>
                            <tr>
                                <th style="width:5%;">No</th>
                                <th style="width:15%; text-align:left;">Kode Barang</th>
                                <th style="text-align:left;">Nama Barang</th>
                                <th style="width:18%;">Barcode</th>
                                <th style="width:15%; text-align:right;">Jumlah</th>
                                <th style="width:15%; text-align:left;">Keterangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_no" t-value="0"/>
                            <t t-foreach="doc.move_ids_without_package" t-as="line">
                                <t t-set="line_no" t-value="line_no + 1"/>
                                <tr>
                                    <td class="text-center"><span t-esc="line_no"/></td>
                                    <td class="text-left"><span t-field="line.product_id.default_code"/></td>
                                    <td class="text-left"><span t-field="line.product_id.name"/></td>
                                    <td class="text-center">
                                        <t t-if="line.product_id.barcode">
                                            <span t-field="line.product_id.barcode" t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 400, 'height': 100, 'img_style': 'width:100%; max-height:25px; object-fit:contain;'}"/>
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="line.quantity_done > 0">
                                            <span t-field="line.quantity_done" t-options='{"widget":"float","precision": 2}'/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="line.product_uom_qty" t-options='{"widget":"float","precision": 2}'/>
                                        </t>
                                        <span t-field="line.product_uom.name" style="margin-left:4px;"/>
                                    </td>
                                    <td class="text-left"></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div t-if="doc.note" style="margin-bottom: 25px; font-size: 12px; color: #333333;">
                        <strong>Catatan Internal:</strong> <span t-field="doc.note"/>
                    </div>

                    <table style="width:100%; margin-top:45px; text-align:center; border-collapse:collapse; page-break-inside:avoid; font-size:13px;">
                        <tr style="vertical-align:top;">
                    
                            <!-- Diberikan oleh -->
                            <td style="width:33.33%; padding:0 10px;">
                    
                                <div style="margin-bottom:70px;">
                                    Diberikan oleh,
                                </div>
                    
                                <div style="border-top:1px solid #000; width:85%; margin:0 auto;"></div>
                    
                                <div style="margin-top:6px; font-size:11px; color:#555;">
                                    (Gudang)
                                </div>
                    
                            </td>
                    
                            <!-- Mengetahui -->
                            <td style="width:33.33%; padding:0 10px;">
                    
                                <div style="margin-bottom:70px;">
                                    Mengetahui,
                                </div>
                    
                                <div style="border-top:1px solid #000; width:85%; margin:0 auto;"></div>
                    
                                <div style="margin-top:6px; font-size:11px; color:#555;">
                                    (Security)
                                </div>
                    
                            </td>
                    
                            <!-- Diterima -->
                            <td style="width:33.33%; padding:0 10px;">
                    
                                <div style="margin-bottom:8px; font-size:12px;">
                                    ....................., ................. 20....
                                </div>
                    
                                <div style="margin-bottom:45px;">
                                    Diterima oleh,
                                </div>
                    
                                <div style="border-top:1px solid #000; width:85%; margin:0 auto;"></div>
                    
                                <div style="margin-top:6px; font-size:11px; color:#555;">
                                    (Nama Terang &amp; Cap)
                                </div>
                    
                            </td>
                    
                        </tr>
                    </table>
                </t>
            </t>
        </t>
    </template>
</odoo>

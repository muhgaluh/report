<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_signature" model="ir.ui.view">
        <field name="name">res.users.form.inherit.signature</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='preferences']" position="inside">
                <group string="Report Signatures">
                    <field name="sign_signature" widget="image" class="oe_avatar" options='{"size": [150, 150]}'/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_users_form_simple_modif_inherit_signature" model="ir.ui.view">
        <field name="name">res.users.preferences.form.inherit.signature</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='preferences']" position="after">
                <group string="Report Signatures">
                    <field name="sign_signature" widget="image" class="oe_avatar" options='{"size": [150, 150]}'/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

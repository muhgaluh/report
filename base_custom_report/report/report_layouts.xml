<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_external_layout">

        <t t-set="o" t-value="o or doc"/>
        <t t-set="company" t-value="company or o.company_id or res_company"/>

        <div class="header">
            <style type="text/css">
                .base-report-uniform, .base-report-uniform * {
                    font-family: Arial, Helvetica, sans-serif !important;
                    font-size: 13px !important;
                    line-height: 1.4 !important;
                }
                .company-name-title {
                    font-size: 18px !important;
                    font-weight: 900 !important;
                    color: #102e5f;
                    margin-bottom: 4px;
                    letter-spacing: 0.5px;
                }
                .company-detail-text {
                    font-size: 11px !important;
                    color: #333333;
                }

                /* =========================================
                   OPSI NUKLIR: PEMBUNUH BORDER GAIB
                   ========================================= */
                .table-no-border,
                .table-no-border tr,
                .table-no-border td,
                .table-no-border th,
                table.table-no-border {
                    border: 0px solid transparent !important;
                    border-style: hidden !important;
                    border-width: 0px !important;
                    outline: none !important;
                    background: transparent !important;
                }

                .divider-header-thick {
                    width: 100%;
                    border-top: 3px solid #102e5f;
                    border-bottom: 1px solid #000000;
                    margin-top: 10px;
                    margin-bottom: 15px;
                }
                .divider-footer-thin {
                    width: 100%;
                    border-top: 1px solid #888888;
                    margin-bottom: 8px;
                }
            </style>

            <div class="base-report-uniform">
                <table class="table-no-border" style="width:100%; table-layout: fixed; border-collapse: collapse;">
                    <tr style="vertical-align:middle;">
                        <td style="width:20%; padding: 0;">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height:85px; max-width: 100%;"/>
                        </td>

                        <td style="width:55%; padding-left: 15px;">
                            <div class="company-name-title">
                                <span t-esc="(company.name or '').upper()"/>
                            </div>
                            <div class="company-detail-text">
                                <div>
                                    <span t-esc="company.street"/>
                                    <span t-if="company.street2" t-esc="company.street2"/>
                                </div>
                                <div>
                                    <span t-esc="company.city"/>
                                    <span t-if="company.state_id" t-esc="', ' + company.state_id.name"/>
                                    <span t-if="company.zip" t-esc="' ' + company.zip"/>
                                </div>
                                <div style="margin-top: 2px;">
                                    <t t-if="company.phone"><strong>T:</strong> <span t-esc="company.phone"/> &#160;|&#160; </t>
                                    <t t-if="company.email"><strong>E:</strong> <span t-esc="company.email"/></t>
                                </div>
                                <div t-if="company.vat" style="margin-top: 2px;">
                                    <strong>NPWP:</strong> <span t-esc="company.vat"/>
                                </div>
                            </div>
                        </td>

                        <td style="width:25%; text-align:right; padding: 0;">
                            <img t-if="company.iso_logo_1" t-att-src="image_data_uri(company.iso_logo_1)" style="max-height:60px; display:inline-block; margin-left:4px;"/>
                            <img t-if="company.iso_logo_2" t-att-src="image_data_uri(company.iso_logo_2)" style="max-height:60px; display:inline-block; margin-left:4px;"/>
                            <img t-if="company.iso_logo_3" t-att-src="image_data_uri(company.iso_logo_3)" style="max-height:60px; display:inline-block; margin-left:4px;"/>
                        </td>
                    </tr>
                </table>

                <div class="divider-header-thick"/>
            </div>
        </div>

        <div class="article base-report-uniform" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-out="0"/>
        </div>

        <div class="footer base-report-uniform">

            <div class="divider-footer-thin"/>

            <div style="width: 100%; font-size: 11px; color: #555555; overflow: hidden; margin-top: 5px;">

                <div style="float: left; width: 33%; text-align: left;">
                    <span t-if="company.website" t-esc="company.website"/>
                </div>

                <div style="float: left; width: 34%; text-align: center;">
                    <span t-if="company.company_registry">Reg: <span t-esc="company.company_registry"/></span>
                </div>

                <div style="float: right; width: 33%; text-align: right; font-weight: bold;">
                    Page <span class="page"/> of <span class="topage"/>
                </div>

            </div>
        </div>

    </template>
</odoo>

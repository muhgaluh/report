<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_iso_base" model="ir.ui.view">
        <field name="name">res.company.form.inherit.iso.base</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Custom Report Logos">
                    <group>
                        <field name="iso_logo_1" widget="image" class="oe_avatar"/>
                        <field name="iso_logo_2" widget="image" class="oe_avatar"/>
                        <field name="iso_logo_3" widget="image" class="oe_avatar"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
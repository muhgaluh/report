<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_preview_wizard_form" model="ir.ui.view">
        <field name="name">report.preview.wizard.form</field>
        <field name="model">report.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Report Preview">
                <field name="name" invisible="1"/>
                <field name="pdf_file" widget="pdf_viewer" nolabel="1"/>
                <footer>
                    <button string="Close Preview" class="btn-primary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>